{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/preventivo/layout,_N_T_/preventivo/page,_N_T_/preventivo"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/preventivo/__PAGE__",
    "/preventivo",
    "/_index",
    "/_head"
  ]
}